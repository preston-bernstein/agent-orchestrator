{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Scoped to src/audit/** — chain logic is the critical security path (design.md §Test plan, vault Build/Audit Hash Chain). Threshold ≥ 80% per tasks.md task 15.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "vitest_comment": {
    "configFile": "vitest.config.ts"
  },
  "checkers": ["typescript"],
  "plugins": [
    "@stryker-mutator/vitest-runner",
    "@stryker-mutator/typescript-checker"
  ],
  "tsconfigFile": "tsconfig.json",
  "mutate": ["src/audit/**/*.ts", "!src/audit/verify.ts"],
  "coverageAnalysis": "perTest",
  "reporters": ["progress", "clear-text", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 80
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true,
  "incremental": false
}
