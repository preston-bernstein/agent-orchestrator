{
  "name": "agent-orchestrator",
  "version": "0.0.0",
  "private": true,
  "description": "Local multi-agent orchestrator (Mastra + optional Inngest) — PoC bootstrap",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test:run": "vitest --run",
    "coverage": "vitest --run --coverage",
    "quality": "pnpm run typecheck && pnpm run lint && pnpm run test:run",
    "orchestrate": "tsx src/cli/orchestrate.ts",
    "audit:verify": "tsx src/audit/verify.ts",
    "scorecard": "tsx src/scorecard/index.ts",
    "mutation": "stryker run"
  },
  "dependencies": {
    "@mastra/core": "^1.31.0",
    "@toon-format/toon": "^2.1.0",
    "p-limit": "^7.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.8"
  }
}
