{
  "name": "agent-orchestrator",
  "version": "0.0.0",
  "private": true,
  "description": "Local multi-agent orchestrator (Mastra + optional Inngest) — PoC bootstrap",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test:run": "vitest --run",
    "coverage": "vitest --run --coverage",
    "quality": "pnpm run typecheck && pnpm run lint && pnpm run coverage && pnpm run fallow",
    "ci": "concurrently -g -n \"tc,lint,fallow,cov\" -c blue,green,cyan,magenta \"pnpm run typecheck\" \"pnpm run lint\" \"pnpm run fallow\" \"pnpm run coverage\" && concurrently -g -n \"t0,wide\" -c yellow,red \"pnpm run mutation:t0\" \"pnpm run mutation:wide\"",
    "ci:seq": "pnpm run quality && pnpm run mutation:t0 && pnpm run mutation:wide",
    "fallow": "fallow --format compact",
    "orchestrate": "tsx src/cli/orchestrate.ts",
    "audit:verify": "tsx src/audit/verify.ts",
    "scorecard": "tsx src/scorecard/index.ts",
    "mutation": "stryker run stryker.conf.json",
    "mutation:t0": "stryker run stryker.conf.json",
    "mutation:wide": "stryker run stryker.wide.conf.json",
    "inngest:serve": "tsx src/inngest/serve.ts",
    "inngest:dev": "npx inngest-cli@latest dev -u http://127.0.0.1:3030/api/inngest",
    "verify:inngest-outbound": "bash scripts/verify-inngest-outbound.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@mastra/core": "^1.31.0",
    "@toon-format/toon": "^2.1.0",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.6.0",
    "inngest": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "fallow": "^2.64.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.8"
  }
}
