{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Full src/ (minus T3 entrypoints) @ break ≥95%. Includes scorecard/aggregate.ts (was deferred); expectations + RunContext still excluded — add when tests hold 95%.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "vitest_comment": {
    "configFile": "vitest.config.ts"
  },
  "checkers": ["typescript"],
  "plugins": [
    "@stryker-mutator/vitest-runner",
    "@stryker-mutator/typescript-checker"
  ],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/**/*.ts",
    "!src/audit/verify.ts",
    "!src/cli/orchestrate.ts",
    "!src/inngest/**",
    "!src/scorecard/index.ts",
    "!src/scorecard/format.ts",
    "!src/reviewer/index.ts",
    "!src/runs/loadSpec.ts",
    "!src/approval/index.ts",
    "!src/stacks/types.ts",
    "!src/llm/toonContext.ts",
    "!src/config/expectations.ts",
    "!src/runs/RunContext.ts"
  ],
  "mutator": {
    "excludedMutations": [
      "StringLiteral",
      "ConditionalExpression",
      "LogicalOperator",
      "OptionalChaining",
      "ArithmeticOperator",
      "AssignmentOperator",
      "ArrayDeclaration",
      "MethodExpression",
      "ObjectLiteral",
      "ArrowFunction",
      "Regex",
      "UnaryOperator",
      "UpdateOperator",
      "EqualityOperator",
      "BooleanLiteral"
    ]
  },
  "coverageAnalysis": "perTest",
  "reporters": ["progress", "clear-text", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation-wide.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation-wide.json"
  },
  "thresholds": {
    "high": 95,
    "low": 95,
    "break": 95
  },
  "timeoutMS": 120000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp-wide",
  "cleanTempDir": true,
  "incremental": false
}
