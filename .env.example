# TrustFoundry — REQUIRED for `pnpm run orchestrate`.
# Boot refuses (non-zero exit) if either is missing.
TF_BASE_URL=https://example.invalid
TF_API_KEY=

# Skip the live capability probe at boot (CI / offline dev).
# TF_SKIP_PROBE=0

RUNS_DIR=./runs

# A3 pin (optional strict)
# EXPECTED_VAULT_SHA=
# STRICT_EXPECTATIONS=0

# Managed repos — required for `--execute` lane (Phase 5 closeout).
# Comma-separated `repo-id:/abs/path`. Each path must contain `docs/_meta.md`
# (vault `Build/RepoKits/<repo>/_meta.md.example`). Absent ⇒ execute lane refuses.
# ORCH_MANAGED_REPOS=spring-api:/abs/path/spring-api,react-ui:/abs/path/react-ui
