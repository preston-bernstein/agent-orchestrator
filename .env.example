# TrustFoundry — REQUIRED for `pnpm run orchestrate`.
# Boot refuses (non-zero exit) if either is missing.
TF_BASE_URL=https://example.invalid
TF_API_KEY=

# Skip the live capability probe at boot (CI / offline dev).
# TF_SKIP_PROBE=0

RUNS_DIR=./runs

# A3 pin (optional strict)
# EXPECTED_VAULT_SHA=
# STRICT_EXPECTATIONS=0

# Managed repos (later)
# API_REPO_ROOT=
# UI_REPO_ROOT=
