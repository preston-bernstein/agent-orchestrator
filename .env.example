# TrustFoundry — REQUIRED for `pnpm run orchestrate`.
# Boot refuses (non-zero exit) if either is missing.
TF_BASE_URL=https://example.invalid
TF_API_KEY=

# Skip the live capability probe at boot (CI / offline dev).
# TF_SKIP_PROBE=0

RUNS_DIR=./runs

# A3 pin (optional strict)
# EXPECTED_VAULT_SHA=
# STRICT_EXPECTATIONS=0

# Managed repos — required for `--execute` lane (Phase 5 closeout).
# Comma-separated `repo-id:/abs/path`. Each path must contain `docs/_meta.md`
# (vault `Build/RepoKits/<repo>/_meta.md.example`). Absent ⇒ execute lane refuses.
# Same env must be present on **`pnpm run inngest:serve`** if `orch/run.requested`
# plans work on managed supervisors.
# ORCH_MANAGED_REPOS=spring-api:/abs/path/spring-api,react-ui:/abs/path/react-ui

# Mock TrustFoundry / subagent completions (offline + Inngest execute until real TF).
# Required on the Inngest worker for `orch/run.requested` execute branch.
# MOCK_TF=1

# Optional: base URL printed in `pnpm run orchestrate` JSON (`audit_url`, artifact viewer).
# ORCH_ARTIFACT_BASE_URL=http://127.0.0.1:3030

# --- Inngest (I2 — outer durable shell; ADR 0002) ---
# `pnpm run orchestrate -- --spec …` POSTs events to dev UI (`pnpm run inngest:dev`).
# Leave `INNGEST_DEV` unset on a laptop → SDK infers dev (no INNGEST_EVENT_KEY).
# Set INNGEST_DEV=0 + INNGEST_EVENT_KEY only for explicit cloud-mode sends.
# **Self-host** dev: `INNGEST_BASE_URL` loopback/internal LAN if you override.
# INNGEST_EVENT_KEY=
# Signing key — worker (`pnpm run inngest:serve`) validates Inngest → app requests.
# INNGEST_SIGNING_KEY=
# INNGEST_BASE_URL=http://127.0.0.1:8288
# Force explicit dev/cloud in SDK: INNGEST_DEV=1 | INNGEST_DEV=0
# INNGEST_DEV=1
