{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["eslint/sonar.standalone.mjs"],
  "project": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mjs",
    "eslint/**/*.mjs"
  ],
  "ignore": ["scripts/build-fixture.ts"],
  "ignoreDependencies": [
    "@mastra/core",
    "@vitest/coverage-istanbul",
    "fallow",
    "madge"
  ],
  "treatConfigHintsAsErrors": true
}
